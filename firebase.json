{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "hosting": {
    "public": "build",
	"site": "anweshan-dev",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "functions": {
		"host": "127.0.0.1",
		"port": 9000
    },
    "firestore": {
		"host": "127.0.0.1",
		"port": 9001
    },
    "hosting": {
		"host": "127.0.0.1",
		"port": 9002
    },
    "pubsub": {
		"host": "127.0.0.1",
		"port": 9003
    },
    "storage": {
		"host": "127.0.0.1",
		"port": 9004
    },
    "ui": {
      "enabled": true,
		"host": "127.0.0.1",
		 "port": 9006
    },
    "singleProjectMode": true
  }
}
