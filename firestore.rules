rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // AppCheck for protection (especially since reCAPTCHA is initialized in src/lib/firebase.ts)
    function isFromApp() {
      return request.appCheck != null;
    }

    // Contact form submissions
    match /contacts/{contactId} {
      allow create: if isFromApp() &&
                    request.resource.data.keys().hasAll(['name', 'email', 'subject', 'message', 'timestamp']);
      allow read, update, delete: if false;
    }

    // Global visitor analytics
    match /analytics/global {
      // Publicly readable so everyone can see the view counts
      allow get: if true;
      
      // Allow creation only if AppCheck is present and fields are valid
      allow create: if isFromApp() && 
                    request.resource.data.keys().hasAll(['views', 'interactions']);
      
      // Allow updates (increments) only if AppCheck is present and only views/interactions are modified
      allow update: if isFromApp() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'interactions']);
      
      allow delete: if false;
    }
  }
}
